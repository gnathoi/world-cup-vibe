# --- Storage -------------------------------------------------------------
# json: writes to data/sweep.json (default in dev)
# kv:   writes to Vercel KV / Upstash via @vercel/kv (default in production)
STORAGE_DRIVER=json

# Vercel KV / Upstash. Required when STORAGE_DRIVER=kv. Auto-injected by the
# Vercel Marketplace integration in production.
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# --- Auth ----------------------------------------------------------------
# 32+ random bytes (hex or base64). Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-something-long-and-random-at-least-32-bytes

# --- Admin ---------------------------------------------------------------
# Single shared password for the /admin gate. Demo override + specials editor.
ADMIN_PASSWORD=change-me

# --- Cron ----------------------------------------------------------------
# Shared secret. Vercel cron requests send this in the Authorization header.
CRON_SECRET=change-me-to-something-random

# --- Data source ---------------------------------------------------------
OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
