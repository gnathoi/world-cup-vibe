# --- Supabase ------------------------------------------------------------
# Cloud project (used for both dev and prod by default).
# Grab keys from: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Only needed once we add public client-side reads. Leave blank for now.
SUPABASE_ANON_KEY=

# Optional: for `supabase db push` from CLI you also need
# SUPABASE_ACCESS_TOKEN — that lives in ~/.supabase or via `supabase login`.

# --- Auth ----------------------------------------------------------------
# 32+ random bytes (hex or base64). Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-something-long-and-random-at-least-32-bytes

# --- Admin ---------------------------------------------------------------
# Single shared password for the /admin gate.
ADMIN_PASSWORD=change-me

# --- Cron ----------------------------------------------------------------
# Vercel cron requests send this in the Authorization header.
CRON_SECRET=change-me-to-something-random

# --- Data source ---------------------------------------------------------
OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
